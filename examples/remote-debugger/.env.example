# Profile: remote-debugger
# Copy to: ~/.hermes/profiles/remote-debugger/.env
# Use UTF-8 without BOM on Windows (doctor reads this file).

TERMINAL_ENV=ssh
TERMINAL_SSH_HOST=192.168.1.100
TERMINAL_SSH_USER=ubuntu
TERMINAL_SSH_PORT=22
TERMINAL_SSH_KEY=~/.ssh/id_rsa

# Copy API keys from default profile or ~/.hermes/.env
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
